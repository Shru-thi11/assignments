
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Facebook Feed</title>
    <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
    <h1>Welcome To Facebook</h1>
    <h2><%= feed.name %></h2>
    <p><%= feed.message %></p>
    <p>Date: <%= feed.date.toDateString() %></p>

<div class="buttons">
    <form action="/feed/delete/<%= feed._id %>" method="POST">
        <button type="submit" >Delete</button>
    </form>
    
    <a href="/feed/edit/<%= feed._id %>">
        <button type="Edit" >Edit Post</button>
    </a>
</div>